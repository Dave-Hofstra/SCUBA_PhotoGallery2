# Server port
PORT=3001

# CORS origin for development (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Session secret (change in production!)
SESSION_SECRET=scuba-gallery-dev-secret-change-in-production

# Admin passcode hash (generate with: node server/scripts/generate-passcode-hash.js <passcode>)
# Default passcode: 5545
ADMIN_PASSCODE_HASH=

# Paths (relative to project root)
PHOTOS_PATH=./photos
CACHE_PATH=./cache
DATABASE_PATH=./data/scuba_gallery.sqlite

# Node environment
NODE_ENV=development